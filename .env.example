# MongoDB connection string — Atlas or local (mongodb://127.0.0.1:27017/ghost_profile)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Full path to Chrome user data directory
# Mac default: /Users/<username>/Library/Application Support/Google/Chrome
CHROME_USER_DATA_DIR=/Users/<username>/Library/Application Support/Google/Chrome

# Chrome profile folder name — find it at chrome://version (look for "Profile Path")
# STRONGLY RECOMMENDED: create a dedicated profile signed into your target Google account
CHROME_PROFILE_NAME=Profile 2

# Port for the Express API server
API_PORT=3737

# Set to "true" to run Chrome headless — NOT recommended, Google detects it
HEADLESS=false

# Dwell time range in milliseconds (how long to sit on each page)
MIN_DWELL_MS=4000
MAX_DWELL_MS=12000
