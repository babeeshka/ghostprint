{
  "name": "ghost-profile",
  "version": "0.1.0",
  "description": "Google Ad Profile polluter — fires randomized searches through a real signed-in Chrome profile",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "api": "tsx src/index.ts",
    "cli": "tsx src/cli.ts",
    "seed": "tsx src/cli.ts seed",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mongoose": "^8.3.4",
    "node-cron": "^3.0.3",
    "playwright": "^1.44.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^7.2.0",
    "mongodb-memory-server": "^11.0.1",
    "supertest": "^7.2.2",
    "tsx": "^4.11.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
